{
  "name": "ogg-spectrum-player",
  "version": "1.0.0",
  "description": "Desktop OGG player with real-time FFT spectrum visualization",
  "main": "dist-electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=20 <23"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build && npm run build:electron",
    "build:electron": "tsc -p tsconfig.electron.json",
    "electron": "electron .",
    "electron:dev": "wait-on tcp:5173 && npm run build:electron && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .",
    "start": "concurrently -k \"npm:dev\" \"npm:electron:dev\""
  },
  "dependencies": {
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@types/react": "^19.1.13",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.1.0",
    "concurrently": "^9.0.1",
    "cross-env": "^7.0.3",
    "electron": "^36.0.0",
    "electron-builder": "^26.8.1",
    "typescript": "^5.8.3",
    "vite": "^7.0.0",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "ogg.spectrum.app",
    "productName": "OGG Spectrum Player",
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ]
  }
}
